<Window x:Class="WorkspaceManager.App.ModeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="模式编辑"
        Width="520"
        Height="500"
        MinWidth="460"
        MinHeight="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}"
                   FontSize="24"
                   FontWeight="SemiBold" />

        <TextBlock Grid.Row="1"
                   Margin="0,10,0,0"
                   Text="自定义模式可配置桌面图标、任务栏和可选布局绑定。"
                   Foreground="{StaticResource MutedTextBrush}"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="2" Margin="0,22,0,0">
            <TextBlock Text="模式名称" FontWeight="SemiBold" />
            <TextBox x:Name="ModeNameTextBox"
                     Margin="0,8,0,0"
                     Height="40"
                     MaxLength="40" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,18,0,0">
            <TextBlock Text="模式说明" FontWeight="SemiBold" />
            <TextBox x:Name="DescriptionTextBox"
                     Margin="0,8,0,0"
                     Height="88"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="DesktopIconsVisibleCheckBox"
                      Content="桌面图标显示"
                      IsChecked="True" />
            <CheckBox x:Name="TaskbarVisibleCheckBox"
                      Grid.Column="1"
                      Margin="12,0,0,0"
                      Content="任务栏显示"
                      IsChecked="True" />
        </Grid>

        <StackPanel Grid.Row="5" Margin="0,18,0,0">
            <TextBlock Text="绑定布局" FontWeight="SemiBold" />
            <ComboBox x:Name="LayoutComboBox"
                      Margin="0,8,0,0"
                      Height="40"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id" />
        </StackPanel>

        <Border x:Name="ValidationBorder"
                Grid.Row="6"
                Margin="0,18,0,0"
                Padding="14"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Visibility="Collapsed">
            <TextBlock x:Name="ValidationTextBlock"
                       Foreground="#DC2626"
                       TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="7" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Width="104"
                    Height="42"
                    Margin="0,0,12,0"
                    Content="取消"
                    Click="Cancel_Click"
                    Style="{StaticResource SecondaryButtonStyle}" />
            <Button Grid.Column="2"
                    Width="124"
                    Height="42"
                    Content="保存模式"
                    Click="Save_Click" />
        </Grid>
    </Grid>
</Window>
