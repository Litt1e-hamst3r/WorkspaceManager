<Window x:Class="WorkspaceManager.App.ModeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="模式编辑"
        Width="640"
        Height="620"
        MinWidth="560"
        MinHeight="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid IsHitTestVisible="False">
            <Ellipse Width="260"
                     Height="260"
                     Margin="-110,-90,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="{StaticResource AccentGlowBrush}" />
            <Ellipse Width="220"
                     Height="220"
                     Margin="0,0,-80,-80"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="{StaticResource ActionGlowBrush}" />
        </Grid>

        <Border Margin="18"
                Style="{StaticResource ShellBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource HeroCardBorderStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource PillBorderStyle}"
                                    Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="模式编辑器"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Margin="0,16,0,0"
                                       Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}"
                                       FontSize="28"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="自定义模式会保存桌面图标、任务栏和可选布局绑定，适合整理不同工作场景。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="模式名称"
                                           FontWeight="SemiBold" />
                                <TextBox x:Name="ModeNameTextBox"
                                         Margin="0,10,0,0"
                                         Height="42"
                                         MaxLength="40" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="名称会用于主窗口模式列表和默认模式选择。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource InsetCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="显示规则"
                                           FontWeight="SemiBold" />
                                <CheckBox x:Name="DesktopIconsVisibleCheckBox"
                                          Margin="0,14,0,0"
                                          Content="桌面图标显示"
                                          IsChecked="True" />
                                <CheckBox x:Name="TaskbarVisibleCheckBox"
                                          Margin="0,12,0,0"
                                          Content="任务栏显示"
                                          IsChecked="True" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="模式说明"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="DescriptionTextBox"
                                     Margin="0,10,0,0"
                                     Height="112"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="说明会显示在模式详情区，建议直接写这个场景适合做什么。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3"
                            Margin="0,18,0,0"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="绑定布局"
                                       FontWeight="SemiBold" />
                            <ComboBox x:Name="LayoutComboBox"
                                      Margin="0,10,0,0"
                                      Height="42"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="切换到该模式时，如已绑定布局，会同步恢复桌面图标位置。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="ValidationBorder"
                            Grid.Row="4"
                            Margin="0,18,0,0"
                            Padding="14"
                            Background="{StaticResource ActionSoftBrush}"
                            BorderBrush="{StaticResource ActionBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ValidationTextBlock"
                                   Foreground="{StaticResource ActionBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Grid Grid.Row="5" Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Width="112"
                                Height="42"
                                Margin="0,0,12,0"
                                Content="取消"
                                Click="Cancel_Click"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Grid.Column="2"
                                Width="136"
                                Height="42"
                                Content="保存模式"
                                Click="Save_Click" />
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
