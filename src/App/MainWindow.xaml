<Window x:Class="WorkspaceManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:WorkspaceManager.App.ViewModels"
        Title="Workspace Manager"
        Height="640"
        Width="920"
        MinHeight="560"
        MinWidth="820"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border Width="84"
                                Height="28"
                                Background="{StaticResource AccentSoftBrush}"
                                CornerRadius="14"
                                HorizontalAlignment="Left">
                            <TextBlock Text="DESKTOP"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding AppName}"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="桌面图标、布局快照和启动设置的集中入口。"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="18,0,12,0"
                            Padding="12,8"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding DesktopIconStateText}"
                                   Foreground="{StaticResource StrongTextBrush}"
                                   FontWeight="SemiBold" />
                    </Border>

                    <Button Grid.Column="2"
                            Width="96"
                            Height="36"
                            Content="{Binding HeaderToggleText}"
                            Click="ToggleHeaderDetails_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Top" />
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,18,0,0"
                      Visibility="{Binding HeaderDetailsVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="把常用操作、布局快照和启动设置放到一个干净的桌面管理入口。"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="需要更多空间时，可以直接收起这块介绍区。"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            MinWidth="260"
                            Margin="24,0,0,0"
                            Padding="18"
                            Background="#0F172A"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock Text="当前状态"
                                       Foreground="#94A3B8"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding DesktopIconStateText}"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding TaskbarStateText}"
                                       Foreground="#CBD5E1"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding HotkeyText}"
                                       Foreground="#CBD5E1" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="0,20,0,0">
            <TabItem Header="概览">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="图标状态" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Margin="0,12,0,0" Text="{Binding DesktopIconStateText}" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0" Text="实时读取桌面图标显隐状态。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="10,0">
                            <StackPanel>
                                <TextBlock Text="快速触发" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Margin="0,12,0,0" Text="{Binding HotkeyText}" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0" Text="支持托盘、按钮和全局快捷键三种入口。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="后台运行" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Margin="0,12,0,0" Text="托盘常驻" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0" Text="最小化和关闭都会隐藏到托盘，不会中断工作流。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="任务栏状态" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Margin="0,12,0,0" Text="{Binding TaskbarStateText}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0" Text="支持快速隐藏或恢复 Windows 任务栏。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="快捷操作" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="常用动作集中在这里，方便你快速试功能。" Foreground="{StaticResource MutedTextBrush}" />

                                <WrapPanel Margin="0,18,0,0">
                                    <Button Width="160" Height="42" Content="切换桌面图标" Click="ToggleDesktopIcons_Click" />
                                    <Button Width="140"
                                            Height="42"
                                            Margin="12,0,0,0"
                                            Content="切换任务栏"
                                            Click="ToggleTaskbar_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Width="120"
                                            Height="42"
                                            Margin="12,0,0,0"
                                            Content="刷新状态"
                                            Click="RefreshState_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>

                                <Border Margin="0,22,0,0"
                                        Padding="16"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <TextBlock Text="提示" FontWeight="SemiBold" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="你现在可以从托盘或主窗口切换桌面图标与任务栏显示状态。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="运行方式" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="当前版本已支持这些行为：" Foreground="{StaticResource MutedTextBrush}" />

                                <StackPanel Margin="0,18,0,0">
                                    <TextBlock Text="• 最小化自动进入托盘" Margin="0,0,0,10" />
                                    <TextBlock Text="• 关闭窗口不退出程序" Margin="0,0,0,10" />
                                    <TextBlock Text="• 双击托盘图标恢复窗口" Margin="0,0,0,10" />
                                    <TextBlock Text="• 任务栏可单独隐藏或恢复" Margin="0,0,0,10" />
                                    <TextBlock Text="• 开机自启与启动最小化可配置" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="布局">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <Border Style="{StaticResource PillBorderStyle}"
                                    Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="布局快照"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </Border>

                            <TextBlock Margin="0,16,0,0" Text="保存当前布局" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="把当前桌面图标位置保存成快照，之后可以一键恢复。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0" Text="布局名称" FontWeight="SemiBold" />
                            <TextBox Margin="0,8,0,0"
                                     Height="40"
                                     Text="{Binding LayoutNameInput, UpdateSourceTrigger=PropertyChanged}" />

                            <WrapPanel Margin="0,18,0,0">
                                <Button Width="120" Height="42" Content="保存布局" Click="SaveLayout_Click" />
                                <Button Width="120"
                                        Height="42"
                                        Margin="12,0,0,0"
                                        Content="刷新列表"
                                        Click="ReloadLayouts_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>

                            <Border Margin="0,20,0,0"
                                    Padding="16"
                                    Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="建议" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="先保存一个“默认布局”，以后桌面图标被打乱时恢复会很方便。"
                                               Foreground="{StaticResource StrongTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="已保存布局" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="选中一个布局后可恢复桌面图标位置，也可以删除旧快照。"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>

                                <Border Grid.Column="1" Style="{StaticResource PillBorderStyle}">
                                    <TextBlock Text="{Binding SavedLayouts.Count, StringFormat=共 {0} 项}" Foreground="{StaticResource MutedTextBrush}" />
                                </Border>
                            </Grid>

                            <Border Grid.Row="1"
                                    Margin="0,18,0,0"
                                    Padding="14"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedLayout.Name, TargetNullValue=选择布局后查看预览}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding SelectedLayout.DisplayText, TargetNullValue=从下方列表选择一个布局快照。}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Style="{StaticResource PillBorderStyle}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding SelectedLayout.ItemCount, TargetNullValue=0, StringFormat=预览 {0} 个图标}"
                                                       Foreground="{StaticResource StrongTextBrush}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Margin="0,14,0,0"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            ClipToBounds="True"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="SelectedLayoutPreview_MouseLeftButtonUp">
                                        <Grid Height="220">
                                            <Border Background="{StaticResource SurfaceAltBrush}" />
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="暂无大图预览"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="选择或重新保存布局后查看"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <Image Source="{Binding SelectedLayout.PreviewImage}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Margin="0,18,0,0"
                                    Padding="12"
                                    MaxHeight="360"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <ListBox ItemsSource="{Binding SavedLayouts}"
                                         SelectedItem="{Binding SelectedLayout}"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:LayoutSummaryViewModel}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="148"
                                                        Height="88"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        BorderBrush="{StaticResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        ClipToBounds="True"
                                                        VerticalAlignment="Top"
                                                        Cursor="Hand"
                                                        MouseLeftButtonUp="LayoutItemPreview_MouseLeftButtonUp">
                                                    <Grid>
                                                        <Border Background="{StaticResource SurfaceAltBrush}" />
                                                        <StackPanel VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center">
                                                            <TextBlock Text="暂无预览"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="保存时自动生成"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                        <Image Source="{Binding ThumbnailImage}"
                                                               Stretch="UniformToFill" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="14,0,12,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding DisplayText}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,10,0,0"
                                                               Text="桌面图标位置快照"
                                                               FontSize="12"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Style="{StaticResource PillBorderStyle}"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding ItemCount, StringFormat={}{0} 个图标}"
                                                               Foreground="{StaticResource StrongTextBrush}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,18,0,0">
                                <Button Width="120" Height="42" Content="恢复布局" Click="RestoreLayout_Click" />
                                <Button Width="120"
                                        Height="42"
                                        Margin="12,0,0,0"
                                        Content="删除布局"
                                        Click="DeleteLayout_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="启动行为" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0" Text="控制应用何时启动、是否直接进入托盘。" Foreground="{StaticResource MutedTextBrush}" />

                            <CheckBox Margin="0,18,0,0"
                                      Content="开机自启"
                                      IsChecked="{Binding LaunchAtStartupEnabled}" />
                            <TextBlock Margin="24,6,0,0" Text="当前用户登录 Windows 后自动启动应用。" Foreground="{StaticResource MutedTextBrush}" />

                            <CheckBox Margin="0,18,0,0"
                                      Content="启动时最小化到托盘"
                                      IsChecked="{Binding StartMinimizedToTrayEnabled}" />
                            <TextBlock Margin="24,6,0,0" Text="启动后不弹出主窗口，直接在托盘后台运行。" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="保存设置" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0" Text="修改会保存到本机，并在下次启动时继续生效。" Foreground="{StaticResource MutedTextBrush}" />

                            <Border Margin="0,18,0,0"
                                    Padding="16"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="当前推荐" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="如果你把它当桌面常驻工具，建议同时开启“开机自启”和“启动时最小化到托盘”。"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,22,0,0">
                                <Button Width="120" Height="42" Content="保存设置" Click="SaveSettings_Click" />
                                <Button Width="120"
                                        Height="42"
                                        Margin="12,0,0,0"
                                        Content="重新加载"
                                        Click="ReloadSettings_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
