<Window x:Class="WorkspaceManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:WorkspaceManager.UI.ViewModels"
        Title="Workspace Manager"
        Icon="pack://application:,,,/Assets/logol.png"
        Height="780"
        Width="1340"
        MinHeight="700"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen">
        <Grid>
        <Grid IsHitTestVisible="False">
            <Ellipse Width="360"
                     Height="360"
                     Margin="-140,-110,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="{StaticResource AccentGlowBrush}" />
            <Ellipse Width="320"
                     Height="320"
                     Margin="0,-80,-100,0"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Fill="{StaticResource ActionGlowBrush}" />
            <Ellipse Width="280"
                     Height="280"
                     Margin="0,0,-120,-120"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="{StaticResource AccentGlowBrush}" />
        </Grid>

        <Border Margin="12"
                Style="{StaticResource ShellBorderStyle}">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="272" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="18,16"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/logol.png"
                                   MaxHeight="40"
                                   Margin="0,2,0,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality" />

                            <StackPanel Grid.Column="1"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="控制面板"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontWeight="SemiBold" />

                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding AppName}"
                                           FontSize="22"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,5,0,0"
                                           Text="{Binding StatusMessage}"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,16,0,0"
                                Padding="14,12"
                                Style="{StaticResource InsetCardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="当前模式"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding CurrentModeText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Width="92"
                                        Height="38"
                                        Content="刷新状态"
                                        Click="RefreshState_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Margin="0,12,0,0"
                                Padding="14,12"
                                Style="{StaticResource InsetCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="状态"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="桌面图标"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DesktopIconStateText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="1"
                                               Margin="0,8,0,0"
                                               Text="任务栏"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Margin="0,8,0,0"
                                               Text="{Binding TaskbarStateText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="2"
                                               Margin="0,8,0,0"
                                               Text="当前模式"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="1"
                                               Margin="0,8,0,0"
                                               Text="{Binding CurrentModeText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="3"
                                               Margin="0,8,0,0"
                                               Text="默认模式"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Grid.Row="3"
                                               Grid.Column="1"
                                               Margin="0,8,0,0"
                                               Text="{Binding DefaultModeText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3"
                                Margin="0,12,0,0"
                                Padding="14,12"
                                Style="{StaticResource InsetCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="快捷键"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding HotkeyText}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4"
                                Margin="0,12,0,0"
                                Padding="14,12"
                                Style="{StaticResource InsetCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="资源"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding Modes.Count, StringFormat=模式：{0}}"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding SavedLayouts.Count, StringFormat=布局：{0}}"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding WallpaperScheduleText}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding WallpaperSourceSummaryText}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <TabControl Grid.Column="2">
            <TabItem Header="概览">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource HeroCardBorderStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <Border Style="{StaticResource PillBorderStyle}"
                                        Background="{StaticResource AccentSoftBrush}"
                                        BorderBrush="{StaticResource AccentSoftBrush}"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="概览"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Margin="0,16,0,0"
                                           Text="常用操作"
                                           FontSize="24"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="查看当前状态，并直接执行桌面、任务栏、模式和壁纸操作。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />

                                <WrapPanel Margin="0,18,0,0">
                                    <Border Margin="0,0,8,8"
                                            Style="{StaticResource PillBorderStyle}"
                                            Background="{StaticResource SurfaceBrush}">
                                        <TextBlock Text="{Binding DesktopIconStateText}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <Border Margin="0,0,8,8"
                                            Style="{StaticResource PillBorderStyle}"
                                            Background="{StaticResource SurfaceBrush}">
                                        <TextBlock Text="{Binding TaskbarStateText}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <Border Margin="0,0,8,8"
                                            Style="{StaticResource PillBorderStyle}"
                                            Background="{StaticResource SurfaceBrush}">
                                        <TextBlock Text="{Binding WallpaperScheduleText}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <Border Margin="0,0,8,8"
                                            Style="{StaticResource PillBorderStyle}"
                                            Background="{StaticResource SurfaceBrush}">
                                        <TextBlock Text="{Binding WallpaperSourceSummaryText}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </WrapPanel>

                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="桌面图标"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                        <Border Margin="0,10,0,0"
                                                Style="{StaticResource SegmentGroupBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Content="显示"
                                                        Click="ShowDesktopIcons_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDesktopIconsVisible}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="1"
                                                        Content="隐藏"
                                                        Click="HideDesktopIcons_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDesktopIconsVisible}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="任务栏"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                        <Border Margin="0,10,0,0"
                                                Style="{StaticResource SegmentGroupBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Content="显示"
                                                        Click="ShowTaskbar_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTaskbarVisible}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="1"
                                                        Content="隐藏"
                                                        Click="HideTaskbar_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTaskbarVisible}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Width="120"
                                            Height="42"
                                            Margin="12,23,0,0"
                                            Content="刷新状态"
                                            Click="RefreshState_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>

                                <TextBlock Margin="0,22,0,0"
                                           Text="快捷操作"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Row="0"
                                            Grid.Column="0"
                                            Margin="0,0,10,10"
                                            Click="ToggleDesktopIcons_Click"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <StackPanel Width="148">
                                            <TextBlock Text="切换桌面图标"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="切换当前显示状态"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Row="0"
                                            Grid.Column="1"
                                            Margin="0,0,10,10"
                                            Click="ToggleTaskbar_Click"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <StackPanel Width="148">
                                            <TextBlock Text="切换任务栏"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="适合演示和录屏场景"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Row="0"
                                            Grid.Column="2"
                                            Margin="0,0,0,10"
                                            Click="ApplyDefaultModeQuickAction_Click"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <StackPanel Width="148">
                                            <TextBlock Text="应用默认模式"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="恢复常用工作配置"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,0,10,0"
                                            Click="ChangeWallpaperNow_Click"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <StackPanel Width="148">
                                            <TextBlock Text="立即换壁纸"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="按当前图源立即切换"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="0,0,10,0"
                                            Click="SaveFavoriteWallpaper_Click"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <StackPanel Width="148">
                                            <TextBlock Text="收藏当前壁纸"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="保存到收藏目录"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Row="1"
                                            Grid.Column="2"
                                            Click="HideWindowToTrayQuickAction_Click"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <StackPanel Width="148">
                                            <TextBlock Text="收起到托盘"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="保留后台运行"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="当前状态" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding CurrentModeText}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding DefaultModeText}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />

                                    <Border Margin="0,16,0,0"
                                            Style="{StaticResource InsetCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding HotkeyText}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Text="{Binding WallpaperScheduleText}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding WallpaperSourceSummaryText}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Margin="0,14,0,0"
                                               Text="可通过托盘或快捷键恢复主窗口。"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="托盘快捷入口" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="托盘菜单提供主窗口、桌面、任务栏、壁纸和默认模式的快捷入口。"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />

                                    <Border Margin="0,16,0,0"
                                            Style="{StaticResource InsetCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="• 显示或收起主窗口" />
                                            <TextBlock Margin="0,8,0,0" Text="• 直接切换桌面图标和任务栏" />
                                            <TextBlock Margin="0,8,0,0" Text="• 直接换下一张壁纸并收藏当前壁纸" />
                                            <TextBlock Margin="0,8,0,0" Text="• 直接应用默认模式" />
                                        </StackPanel>
                                    </Border>

                                    <Button Margin="0,16,0,0"
                                            Content="收起主窗口"
                                            Click="HideWindowToTrayQuickAction_Click" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="模式">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="模式"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="选择、应用和维护桌面模式。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource PillBorderStyle}"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Modes.Count, StringFormat=共 {0} 项}"
                                                   Foreground="{StaticResource StrongTextBrush}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2" Margin="0,18,0,0">
                                    <Border Padding="10"
                                            Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <ListBox ItemsSource="{Binding Modes}"
                                                 SelectedItem="{Binding SelectedMode}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 MaxHeight="420">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:DesktopModeViewModel}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="16"
                                                                           FontWeight="SemiBold"
                                                                           VerticalAlignment="Center" />

                                                                <Border Grid.Column="1"
                                                                        Margin="8,0,0,0"
                                                                        Style="{StaticResource PillBorderStyle}"
                                                                        Background="{StaticResource AccentSoftBrush}"
                                                                        BorderBrush="{StaticResource AccentSoftBrush}"
                                                                        Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="当前"
                                                                               Foreground="{StaticResource AccentBrush}"
                                                                               FontWeight="SemiBold" />
                                                                </Border>

                                                                <Border Grid.Column="2"
                                                                        Margin="8,0,0,0"
                                                                        Style="{StaticResource PillBorderStyle}"
                                                                        Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="默认"
                                                                               Foreground="{StaticResource StrongTextBrush}"
                                                                               FontWeight="SemiBold" />
                                                                </Border>
                                                            </Grid>

                                                            <TextBlock Margin="0,6,0,0"
                                                                       Text="{Binding Description}"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       TextWrapping="Wrap" />

                                                            <Border Margin="0,12,0,0"
                                                                    Padding="10,8"
                                                                    Background="{StaticResource SurfaceBrush}"
                                                                    BorderBrush="{StaticResource CardBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding LayoutName, TargetNullValue=未绑定布局, StringFormat=绑定布局: {0}}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <WrapPanel Margin="0,5,0,0">
                                                                        <TextBlock Text="{Binding KindText, TargetNullValue=未分类, StringFormat=类型 {0}}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource MutedTextBrush}" />
                                                                        <TextBlock Margin="8,0"
                                                                                   Text="·"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource MutedTextBrush}" />
                                                                        <TextBlock Text="{Binding DesktopIconsVisibleText, TargetNullValue=--, StringFormat=图标 {0}}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource MutedTextBrush}" />
                                                                        <TextBlock Margin="8,0"
                                                                                   Text="·"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource MutedTextBrush}" />
                                                                        <TextBlock Text="{Binding TaskbarVisibleText, TargetNullValue=--, StringFormat=任务栏 {0}}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource MutedTextBrush}" />
                                                                    </WrapPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>

                                    <Button Height="44"
                                            Margin="0,14,0,0"
                                            Content="新建自定义模式"
                                            Click="AddCustomMode_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedMode.Name, TargetNullValue=选择一个模式}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding SelectedMode.Description, TargetNullValue=从左侧选择一个模式后查看详情。}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                        <Border Style="{StaticResource PillBorderStyle}"
                                                Background="{StaticResource AccentSoftBrush}"
                                                BorderBrush="{StaticResource AccentSoftBrush}"
                                                Margin="8,0,0,0"
                                                Visibility="{Binding SelectedMode.IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="当前"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <Border Style="{StaticResource PillBorderStyle}"
                                                Margin="8,0,0,0"
                                                Visibility="{Binding SelectedMode.IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="默认"
                                                       Foreground="{StaticResource StrongTextBrush}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="1"
                                        Margin="0,18,0,0"
                                        Padding="16"
                                        Style="{StaticResource InsetCardBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="1.1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,18,0">
                                            <TextBlock Text="概览"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding SelectedMode.LayoutName, TargetNullValue=未绑定布局}"
                                                       FontSize="24"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Text="{Binding SelectedMode.Description, TargetNullValue=该模式暂无说明。}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />

                                            <WrapPanel Margin="0,16,0,0">
                                                <Border Margin="0,0,8,8"
                                                        Style="{StaticResource PillBorderStyle}"
                                                        Background="{StaticResource SurfaceBrush}">
                                                    <TextBlock Text="{Binding SelectedMode.KindText, TargetNullValue=未分类, StringFormat=类型 {0}}"
                                                               Foreground="{StaticResource StrongTextBrush}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <Border Margin="0,0,8,8"
                                                        Style="{StaticResource PillBorderStyle}"
                                                        Background="{StaticResource SurfaceBrush}">
                                                    <TextBlock Text="{Binding SelectedMode.DesktopIconsVisibleText, TargetNullValue=--, StringFormat=图标 {0}}"
                                                               Foreground="{StaticResource StrongTextBrush}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <Border Margin="0,0,8,8"
                                                        Style="{StaticResource PillBorderStyle}"
                                                        Background="{StaticResource SurfaceBrush}">
                                                    <TextBlock Text="{Binding SelectedMode.TaskbarVisibleText, TargetNullValue=--, StringFormat=任务栏 {0}}"
                                                               Foreground="{StaticResource StrongTextBrush}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </WrapPanel>

                                            <Border Margin="0,18,0,0"
                                                    Padding="12"
                                                    Background="{StaticResource SurfaceBrush}"
                                                    BorderBrush="{StaticResource CardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <TextBlock Text="{Binding SelectedMode.StateSummary, TargetNullValue=模式状态将在这里显示。}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Padding="14"
                                                Background="{StaticResource SurfaceBrush}"
                                                BorderBrush="{StaticResource CardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                VerticalAlignment="Stretch">
                                            <StackPanel>
                                                <TextBlock Text="状态"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding CurrentModeText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />

                                                <Border Height="1"
                                                        Margin="0,16,0,16"
                                                        Background="{StaticResource CardBorderBrush}" />

                                                <TextBlock Text="默认模式"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding DefaultModeText}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />

                                                <Border Height="1"
                                                        Margin="0,16,0,16"
                                                        Background="{StaticResource CardBorderBrush}" />

                                                <TextBlock Text="桌面设置"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding SelectedMode.DesktopIconsVisibleText, TargetNullValue=--, StringFormat=图标 {0}}"
                                                           Foreground="{StaticResource StrongTextBrush}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding SelectedMode.TaskbarVisibleText, TargetNullValue=--, StringFormat=任务栏 {0}}"
                                                           Foreground="{StaticResource StrongTextBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2"
                                        Margin="0,18,0,0"
                                        Padding="16"
                                        Style="{StaticResource InsetCardBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="220" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="布局绑定" FontWeight="SemiBold" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="模式应用时，会一并恢复这里选择的桌面布局。"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <ComboBox Margin="0,14,0,0"
                                                      Height="40"
                                                      ItemsSource="{Binding ModeLayoutOptions}"
                                                      DisplayMemberPath="Name"
                                                      SelectedValuePath="Id"
                                                      SelectedValue="{Binding SelectedModeLayoutId, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Padding="12"
                                                Background="{StaticResource SurfaceBrush}"
                                                BorderBrush="{StaticResource CardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock Text="当前绑定"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding SelectedMode.LayoutName, TargetNullValue=未绑定布局}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="3" Margin="0,22,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Width="148"
                                            Height="44"
                                            Content="应用模式"
                                            Click="ApplyMode_Click" />

                                    <WrapPanel Grid.Column="1"
                                               HorizontalAlignment="Right">
                                        <Button Width="120"
                                                Height="44"
                                                Margin="0,0,10,10"
                                                Content="保存绑定"
                                                Click="SaveModeLayoutBinding_Click"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Width="120"
                                                Height="44"
                                                Margin="0,0,10,10"
                                                Content="设为默认"
                                                Click="SetDefaultMode_Click"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Width="120"
                                                Height="44"
                                                Margin="0,0,10,10"
                                                Content="编辑模式"
                                                Click="EditCustomMode_Click"
                                                IsEnabled="{Binding SelectedMode.IsCustom, TargetNullValue=False}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Width="120"
                                                Height="44"
                                                Content="删除模式"
                                                Click="DeleteCustomMode_Click"
                                                IsEnabled="{Binding SelectedMode.IsCustom, TargetNullValue=False}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </WrapPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="布局">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="保存布局" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="保存当前桌面图标位置，后续可直接恢复。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0" Text="布局名称" FontWeight="SemiBold" />
                            <TextBox Margin="0,8,0,0"
                                     Height="40"
                                     Text="{Binding LayoutNameInput, UpdateSourceTrigger=PropertyChanged}" />

                            <WrapPanel Margin="0,18,0,0">
                                <Button Width="120" Height="42" Content="保存布局" Click="SaveLayout_Click" />
                                <Button Width="120"
                                        Height="42"
                                        Margin="12,0,0,0"
                                        Content="刷新列表"
                                        Click="ReloadLayouts_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>

                            <Border Margin="0,20,0,0"
                                    Padding="16"
                                    Style="{StaticResource InsetCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="提示" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="先保存一个“默认布局”，以后桌面图标被打乱时恢复会很方便。"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="已保存布局" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="选择布局后可查看预览、恢复或删除。"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>

                                <Border Grid.Column="1" Style="{StaticResource PillBorderStyle}">
                                    <TextBlock Text="{Binding SavedLayouts.Count, StringFormat=共 {0} 项}" Foreground="{StaticResource MutedTextBrush}" />
                                </Border>
                            </Grid>

                            <Border Grid.Row="1"
                                    Margin="0,18,0,0"
                                    Padding="14"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedLayout.Name, TargetNullValue=选择布局后查看预览}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding SelectedLayout.DisplayText, TargetNullValue=从下方列表选择一个布局快照。}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Style="{StaticResource PillBorderStyle}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding SelectedLayout.ItemCount, TargetNullValue=0, StringFormat=预览 {0} 个图标}"
                                                       Foreground="{StaticResource StrongTextBrush}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Margin="0,14,0,0"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            ClipToBounds="True"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="SelectedLayoutPreview_MouseLeftButtonUp">
                                        <Grid Height="220">
                                            <Border Background="{StaticResource SurfaceAltBrush}" />
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="暂无大图预览"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="选择或重新保存布局后查看"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <Image Source="{Binding SelectedLayout.PreviewImage}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Margin="0,18,0,0"
                                    Padding="12"
                                    MaxHeight="360"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <ListBox ItemsSource="{Binding SavedLayouts}"
                                         SelectedItem="{Binding SelectedLayout}"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:LayoutSummaryViewModel}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="148"
                                                        Height="88"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        BorderBrush="{StaticResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        ClipToBounds="True"
                                                        VerticalAlignment="Top"
                                                        Cursor="Hand"
                                                        MouseLeftButtonUp="LayoutItemPreview_MouseLeftButtonUp">
                                                    <Grid>
                                                        <Border Background="{StaticResource SurfaceAltBrush}" />
                                                        <StackPanel VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center">
                                                            <TextBlock Text="暂无预览"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="保存时自动生成"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                        <Image Source="{Binding ThumbnailImage}"
                                                               Stretch="UniformToFill" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="14,0,12,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding DisplayText}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Style="{StaticResource PillBorderStyle}"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding ItemCount, StringFormat={}{0} 个图标}"
                                                               Foreground="{StaticResource StrongTextBrush}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,18,0,0">
                                <Button Width="120" Height="42" Content="恢复布局" Click="RestoreLayout_Click" />
                                <Button Width="120"
                                        Height="42"
                                        Margin="12,0,0,0"
                                        Content="删除布局"
                                        Click="DeleteLayout_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="壁纸">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,14,4,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.9*" />
                            <ColumnDefinition Width="1.1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,12,12"
                                Padding="18"
                                Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="壁纸"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="图源、启动切换和定时轮换。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Padding="14,12"
                                            Style="{StaticResource InsetCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="当前状态"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding WallpaperScheduleText}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding WallpaperSourceSummaryText}"
                                                       Foreground="{StaticResource StrongTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Height="40"
                                                        Content="立即切换"
                                                        Click="ChangeWallpaperNow_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsWallpaperChangeInProgress}" Value="True">
                                                                    <Setter Property="Content" Value="切换中..." />
                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="2"
                                                        Height="40"
                                                        Content="收藏当前"
                                                        Click="SaveFavoriteWallpaper_Click"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Margin="0,0,10,0"
                                            Padding="14,12"
                                            Style="{StaticResource InsetCardBorderStyle}">
                                        <StackPanel>
                                            <CheckBox Content="启动后自动切换一张壁纸"
                                                      FontWeight="SemiBold"
                                                      IsChecked="{Binding WallpaperChangeOnStartupEnabled}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Padding="14,12"
                                            Style="{StaticResource InsetCardBorderStyle}">
                                        <StackPanel>
                                            <CheckBox Content="启用定时轮换"
                                                      FontWeight="SemiBold"
                                                      IsChecked="{Binding WallpaperAutoRotateEnabled}" />
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock VerticalAlignment="Center"
                                                           Text="轮换间隔（分钟）"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                                <TextBox Grid.Column="1"
                                                         Height="38"
                                                         Margin="10,0,0,0"
                                                         VerticalContentAlignment="Center"
                                                         IsEnabled="{Binding WallpaperAutoRotateEnabled}"
                                                         Text="{Binding WallpaperRotationIntervalMinutesInput, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,0,12"
                                Padding="18"
                                Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock
                                           Text="添加图源"
                                           FontSize="18"
                                           FontWeight="SemiBold" />

                                <Grid Margin="0,14,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               Text="名称"
                                               FontWeight="SemiBold" />
                                    <TextBox Grid.Column="1"
                                             Height="38"
                                             Margin="10,0,0,0"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding NewWallpaperSourceName, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="1"
                                               Margin="0,12,0,0"
                                               VerticalAlignment="Center"
                                               Text="地址/路径"
                                               FontWeight="SemiBold" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Height="38"
                                             Margin="10,12,0,0"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding NewWallpaperSourceUrl, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <WrapPanel Margin="0,14,0,0">
                                    <Button Width="138"
                                            Margin="0,0,10,10"
                                            Content="添加到图源库"
                                            Click="AddWallpaperSource_Click" />
                                    <Button Width="118"
                                            Margin="0,0,10,10"
                                            Content="选择本地图片"
                                            Click="SelectLocalWallpaperFile_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Width="118"
                                            Margin="0,0,10,10"
                                            Content="选择文件夹"
                                            Click="SelectLocalWallpaperFolder_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Padding="18"
                                Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="图源库"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="在线地址、本地图片和文件夹统一在这里管理。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource PillBorderStyle}"
                                            Background="{StaticResource SurfaceAltBrush}">
                                        <TextBlock Text="{Binding WallpaperSourceSummaryText}"
                                                   Foreground="{StaticResource StrongTextBrush}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                                <Border Margin="0,14,0,0"
                                        Padding="10"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <ListBox ItemsSource="{Binding WallpaperSources}"
                                             MaxHeight="320"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Focusable" Value="False" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type viewModels:WallpaperSourceViewModel}">
                                                <Border Margin="0,0,0,8"
                                                        Padding="12,10"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasHealthIssue}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource ActionBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2.4*" />
                                                            <ColumnDefinition Width="1.1*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Margin="0,0,12,0">
                                                            <CheckBox Content="{Binding Name}"
                                                                      FontWeight="SemiBold"
                                                                      VerticalAlignment="Center"
                                                                      IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <TextBlock Margin="24,4,0,0"
                                                                       Text="{Binding RequestUrl}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       TextWrapping="NoWrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding RequestUrl}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1"
                                                                    Margin="0,0,12,0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding SourceTypeText}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource MutedTextBrush}" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       FontSize="12"
                                                                       Text="{Binding AvailabilityDetailText}"
                                                                       TextWrapping="NoWrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding AvailabilityDetailText}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasHealthIssue}" Value="True">
                                                                                <Setter Property="Foreground" Value="{StaticResource ActionBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Top">
                                                            <Border Padding="10,4"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                                                        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentSoftStrongBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding EnabledText}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource StrongTextBrush}" />
                                                            </Border>
                                                            <Border Margin="8,0,0,0"
                                                                    Padding="10,4"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentSoftStrongBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasHealthIssue}" Value="True">
                                                                                <Setter Property="Background" Value="{StaticResource ActionSoftBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{StaticResource ActionBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding AvailabilityText}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasHealthIssue}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{StaticResource ActionBrush}" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="3"
                                                                    Orientation="Horizontal"
                                                                    Margin="12,0,0,0"
                                                                    VerticalAlignment="Top">
                                                            <Button Width="74"
                                                                    Height="34"
                                                                    Content="重选"
                                                                    Click="ReselectLocalWallpaperFile_Click"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Visibility="{Binding CanReselect, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            <Button Width="74"
                                                                    Height="34"
                                                                    Margin="8,0,0,0"
                                                                    Content="删除"
                                                                    Click="DeleteWallpaperSource_Click"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Visibility="{Binding CanDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <WrapPanel Margin="0,14,0,0">
                                    <Button Width="132"
                                            Margin="0,0,10,10"
                                            Content="保存壁纸设置"
                                            Click="SaveWallpaperSettings_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Width="116"
                                            Margin="0,0,10,10"
                                            Content="重新加载"
                                            Click="ReloadWallpaperSettings_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Width="116"
                                            Margin="0,0,10,10"
                                            Content="全部启用"
                                            Click="EnableAllWallpaperSources_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="启动行为" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="以下设置在保存后生效。" Foreground="{StaticResource MutedTextBrush}" />

                                <CheckBox Margin="0,18,0,0"
                                          Content="开机自启"
                                          IsChecked="{Binding LaunchAtStartupEnabled}" />

                                <CheckBox Margin="0,18,0,0"
                                          Content="启动时最小化到托盘"
                                          IsChecked="{Binding StartMinimizedToTrayEnabled}" />

                                <CheckBox Margin="0,18,0,0"
                                          Content="最小化时隐藏到托盘"
                                          IsChecked="{Binding MinimizeToTrayOnMinimizeEnabled}" />

                                <CheckBox Margin="0,18,0,0"
                                          Content="关闭窗口时隐藏到托盘"
                                          IsChecked="{Binding CloseToTrayOnCloseEnabled}" />

                                <TextBlock Margin="0,18,0,0" Text="默认模式" FontWeight="SemiBold" />
                                <ComboBox Margin="0,8,0,0"
                                          Height="40"
                                          ItemsSource="{Binding ModeOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding DefaultModeId, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="应用启动后会自动切到这里选中的模式。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="快捷键与保存" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="修改后保存即可立即生效。" Foreground="{StaticResource MutedTextBrush}" />

                                <TextBlock Margin="0,18,0,0" Text="桌面图标切换快捷键" FontWeight="SemiBold" />
                                <TextBox Margin="0,8,0,0"
                                         Height="40"
                                         IsReadOnly="True"
                                         Cursor="Hand"
                                         ToolTip="点击后直接按组合键"
                                         PreviewMouseLeftButtonDown="HotkeyCapture_PreviewMouseLeftButtonDown"
                                         GotKeyboardFocus="HotkeyCapture_GotKeyboardFocus"
                                         PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                         PreviewTextInput="HotkeyCapture_PreviewTextInput"
                                         Tag="DesktopToggle"
                                         Text="{Binding DesktopToggleHotkeyInput, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,18,0,0" Text="主窗口显隐快捷键" FontWeight="SemiBold" />
                                <TextBox Margin="0,8,0,0"
                                         Height="40"
                                         IsReadOnly="True"
                                         Cursor="Hand"
                                         ToolTip="点击后直接按组合键"
                                         PreviewMouseLeftButtonDown="HotkeyCapture_PreviewMouseLeftButtonDown"
                                         GotKeyboardFocus="HotkeyCapture_GotKeyboardFocus"
                                         PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                         PreviewTextInput="HotkeyCapture_PreviewTextInput"
                                         Tag="ShowMainWindow"
                                         Text="{Binding ShowMainWindowHotkeyInput, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,18,0,0" Text="收藏壁纸保存路径" FontWeight="SemiBold" />
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Height="40"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding WallpaperFavoriteSaveDirectoryInput, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1"
                                            Width="96"
                                            Height="40"
                                            Margin="10,0,0,0"
                                            Content="选择文件夹"
                                            Click="SelectFavoriteWallpaperSaveDirectory_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                                <TextBlock Margin="0,8,0,0"
                                           Text="仅影响“收藏当前”的保存位置。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />

                                <Border Margin="0,18,0,0"
                                        Padding="16"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="录入规则" FontWeight="SemiBold" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="支持 Ctrl、Alt、Shift、Win。快捷键需包含修饰键；按 Esc 可取消录入。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <WrapPanel Margin="0,22,0,0">
                                    <Button Width="120" Height="42" Content="保存设置" Click="SaveSettings_Click" />
                                    <Button Width="120"
                                            Height="42"
                                            Margin="12,0,0,0"
                                            Content="重新加载"
                                            Click="ReloadSettings_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>


