<Window x:Class="WorkspaceManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:WorkspaceManager.UI.ViewModels"
        Title="Workspace Manager"
        Icon="pack://application:,,,/Assets/logol.png"
        Height="780"
        Width="1340"
        MinHeight="700"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen">
        <Grid>
        <Grid IsHitTestVisible="False">
            <Ellipse Width="360"
                     Height="360"
                     Margin="-140,-110,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="{StaticResource AccentGlowBrush}" />
            <Ellipse Width="320"
                     Height="320"
                     Margin="0,-80,-100,0"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Fill="{StaticResource ActionGlowBrush}" />
            <Ellipse Width="280"
                     Height="280"
                     Margin="0,0,-120,-120"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="{StaticResource AccentGlowBrush}" />
        </Grid>

        <Border Margin="12"
                Style="{StaticResource ShellBorderStyle}">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="18,16"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/logol.png"
                                   MaxHeight="46"
                                   Margin="0,2,0,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality" />

                            <StackPanel Grid.Column="1"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Center">
                                <Border Style="{StaticResource PillBorderStyle}"
                                        Background="{StaticResource AccentSoftBrush}"
                                        BorderBrush="{StaticResource AccentSoftBrush}"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="桌面工作台"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold" />
                                </Border>

                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding AppName}"
                                           FontSize="24"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,5,0,0"
                                           Text="{Binding StatusMessage}"
                                           FontSize="13"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,16,0,0"
                                Padding="14,12"
                                Style="{StaticResource InsetCardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="当前模式"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding CurrentModeText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Width="92"
                                        Height="38"
                                        Content="刷新状态"
                                        Click="RefreshState_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Margin="0,0,8,0"
                                    Padding="14,12"
                                    Style="{StaticResource InsetCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="桌面图标"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding DesktopIconStateText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Padding="14,12"
                                    Style="{StaticResource InsetCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="任务栏"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding TaskbarStateText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3"
                                Margin="0,12,0,0"
                                Padding="14,12"
                                Style="{StaticResource InsetCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="快捷键"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding HotkeyText}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="4" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Margin="0,0,8,0"
                                    Padding="14,12"
                                    Style="{StaticResource InsetCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="默认模式"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding DefaultModeText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Padding="14,12"
                                    Style="{StaticResource InsetCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="资源概览"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding Modes.Count, StringFormat={}{0} 个模式}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding SavedLayouts.Count, StringFormat={}{0} 份布局}"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <TabControl Grid.Column="2">
            <TabItem Header="概览">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <Border Style="{StaticResource PillBorderStyle}"
                                        Background="{StaticResource AccentSoftBrush}"
                                        BorderBrush="{StaticResource AccentSoftBrush}"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="工作区状态"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Margin="0,16,0,0"
                                           Text="当前桌面控制入口"
                                           FontSize="24"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="图标、任务栏、托盘与快捷键都集中在这里，日常切换会更直接。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />

                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="桌面图标"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                        <Border Margin="0,10,0,0"
                                                Style="{StaticResource SegmentGroupBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Content="显示"
                                                        Click="ShowDesktopIcons_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDesktopIconsVisible}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="1"
                                                        Content="隐藏"
                                                        Click="HideDesktopIcons_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDesktopIconsVisible}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="任务栏"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                        <Border Margin="0,10,0,0"
                                                Style="{StaticResource SegmentGroupBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Content="显示"
                                                        Click="ShowTaskbar_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTaskbarVisible}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="1"
                                                        Content="隐藏"
                                                        Click="HideTaskbar_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTaskbarVisible}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Width="120"
                                            Height="42"
                                            Margin="12,23,0,0"
                                            Content="刷新状态"
                                            Click="RefreshState_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>

                                <Border Margin="0,22,0,0"
                                        Padding="16"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="桌面图标" FontWeight="SemiBold" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding DesktopIconStateText}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                            <TextBlock Text="任务栏" FontWeight="SemiBold" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding TaskbarStateText}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="当前状态" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding HotkeyText}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="双击托盘图标可恢复窗口，快捷键可快速切换桌面图标。"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding CurrentModeText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding DefaultModeText}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="运行方式" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,14,0,0" Text="• 最小化自动进入托盘" />
                                    <TextBlock Margin="0,8,0,0" Text="• 关闭窗口不退出程序" />
                                    <TextBlock Margin="0,8,0,0" Text="• 任务栏可单独隐藏或恢复" />
                                    <TextBlock Margin="0,8,0,0" Text="• 支持开机自启与启动最小化" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="模式">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource PillBorderStyle}"
                                        Background="{StaticResource AccentSoftBrush}"
                                        BorderBrush="{StaticResource AccentSoftBrush}"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="模式列表"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold" />
                                </Border>

                                <TextBlock Grid.Row="1" Margin="0,16,0,0" Text="快速切换工作场景" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Margin="0,8,0,0"
                                           Text="模式会联动桌面图标、任务栏和可选布局快照，支持预设模式和自定义模式。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />

                                <StackPanel Grid.Row="3" Margin="0,18,0,0">
                                    <Border Padding="10"
                                            Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <ListBox ItemsSource="{Binding Modes}"
                                                 SelectedItem="{Binding SelectedMode}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 MaxHeight="420">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:DesktopModeViewModel}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border CornerRadius="8"
                                                                Margin="0,0,12,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Id}" Value="work">
                                                                            <Setter Property="Background" Value="#16A34A" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Id}" Value="presentation">
                                                                            <Setter Property="Background" Value="#7C3AED" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>

                                                        <StackPanel Grid.Column="1">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="16"
                                                                           FontWeight="SemiBold"
                                                                           VerticalAlignment="Center" />

                                                                <Border Grid.Column="1"
                                                                        Margin="8,0,0,0"
                                                                        Style="{StaticResource PillBorderStyle}"
                                                                        Background="{StaticResource AccentSoftBrush}"
                                                                        BorderBrush="{StaticResource AccentSoftBrush}"
                                                                        Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="当前"
                                                                               Foreground="{StaticResource AccentBrush}"
                                                                               FontWeight="SemiBold" />
                                                                </Border>

                                                                <Border Grid.Column="2"
                                                                        Margin="8,0,0,0"
                                                                        Style="{StaticResource PillBorderStyle}"
                                                                        Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="默认"
                                                                               Foreground="{StaticResource StrongTextBrush}"
                                                                               FontWeight="SemiBold" />
                                                                </Border>
                                                            </Grid>

                                                            <TextBlock Margin="0,8,0,0"
                                                                       Text="{Binding Description}"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       TextWrapping="Wrap" />

                                                            <WrapPanel Margin="0,12,0,0">
                                                                <Border Margin="0,0,8,8"
                                                                        Padding="10,6"
                                                                        Background="{StaticResource SurfaceBrush}"
                                                                        BorderBrush="{StaticResource CardBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="999">
                                                                    <TextBlock FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding DesktopIconsVisibleText, Mode=OneWay, StringFormat=图标 · {0}}" />
                                                                </Border>
                                                                <Border Margin="0,0,8,8"
                                                                        Padding="10,6"
                                                                        Background="{StaticResource SurfaceBrush}"
                                                                        BorderBrush="{StaticResource CardBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="999">
                                                                    <TextBlock FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding TaskbarVisibleText, Mode=OneWay, StringFormat=任务栏 · {0}}" />
                                                                </Border>
                                                                <Border Margin="0,0,8,8"
                                                                        Padding="10,6"
                                                                        Background="{StaticResource SurfaceBrush}"
                                                                        BorderBrush="{StaticResource CardBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="999">
                                                                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                               Text="{Binding LayoutName, StringFormat=布局 · {0}}" />
                                                                </Border>
                                                                <Border Margin="0,0,8,8"
                                                                        Padding="10,6"
                                                                        Background="{StaticResource SurfaceBrush}"
                                                                        BorderBrush="{StaticResource CardBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="999">
                                                                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                               Text="{Binding KindText}" />
                                                                </Border>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>

                                    <Button Height="44"
                                            Margin="0,14,0,0"
                                            Content="＋ 新建自定义模式"
                                            Click="AddCustomMode_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Padding="20"
                                        Background="#F8FBFF"
                                        BorderBrush="#D8E6FF"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedMode.Name, TargetNullValue=选择一个模式}"
                                                       FontSize="24"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding SelectedMode.Description, TargetNullValue=从左侧选择一个模式后查看详情。}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                            <Border Style="{StaticResource PillBorderStyle}"
                                                    Background="{StaticResource AccentSoftBrush}"
                                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                                    Margin="8,0,0,0"
                                                    Visibility="{Binding SelectedMode.IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="当前模式"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                            <Border Style="{StaticResource PillBorderStyle}"
                                                    Margin="8,0,0,0"
                                                    Visibility="{Binding SelectedMode.IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="启动默认"
                                                           Foreground="{StaticResource StrongTextBrush}"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1.2*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="桌面图标" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding SelectedMode.DesktopIconsVisibleText, TargetNullValue=--, StringFormat=状态：{0}}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="任务栏" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding SelectedMode.TaskbarVisibleText, TargetNullValue=--, StringFormat=状态：{0}}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="布局绑定" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding SelectedMode.LayoutName, TargetNullValue=未绑定布局}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2" Margin="0,18,0,0">
                                    <TextBlock Text="绑定布局" FontWeight="SemiBold" />
                                    <ComboBox Margin="0,8,0,0"
                                              Height="40"
                                              ItemsSource="{Binding ModeLayoutOptions}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedModeLayoutId, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="切换到该模式时，如已绑定布局，会同步恢复桌面图标位置。"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                                                <WrapPanel Grid.Row="3" Margin="0,22,0,0">
                                    <Button Width="128"
                                            Height="44"
                                            Margin="0,0,10,10"
                                            Content="应用模式"
                                            Click="ApplyMode_Click" />
                                    <Button Width="128"
                                            Height="44"
                                            Margin="0,0,10,10"
                                            Content="保存绑定"
                                            Click="SaveModeLayoutBinding_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Width="128"
                                            Height="44"
                                            Margin="0,0,10,10"
                                            Content="设为默认"
                                            Click="SetDefaultMode_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Width="128"
                                            Height="44"
                                            Margin="0,0,10,10"
                                            Content="编辑模式"
                                            Click="EditCustomMode_Click"
                                            IsEnabled="{Binding SelectedMode.IsCustom, TargetNullValue=False}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Width="128"
                                            Height="44"
                                            Margin="0,0,0,10"
                                            Content="删除模式"
                                            Click="DeleteCustomMode_Click"
                                            IsEnabled="{Binding SelectedMode.IsCustom, TargetNullValue=False}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>

                                <Border Grid.Row="4"
                                        Margin="0,20,0,0"
                                        Padding="16"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="当前状态" FontWeight="SemiBold" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding CurrentModeText}"
                                                       Foreground="{StaticResource StrongTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding SelectedMode.StateSummary, TargetNullValue=模式状态将在这里显示。}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                            <TextBlock Text="启动偏好" FontWeight="SemiBold" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding DefaultModeText}"
                                                       Foreground="{StaticResource StrongTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="建议把最常用的场景设为默认模式，启动后会自动应用。"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="布局">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <Border Style="{StaticResource PillBorderStyle}"
                                    Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="布局快照"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </Border>

                            <TextBlock Margin="0,16,0,0" Text="保存当前布局" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="把当前桌面图标位置保存成快照，之后可以一键恢复。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0" Text="布局名称" FontWeight="SemiBold" />
                            <TextBox Margin="0,8,0,0"
                                     Height="40"
                                     Text="{Binding LayoutNameInput, UpdateSourceTrigger=PropertyChanged}" />

                            <WrapPanel Margin="0,18,0,0">
                                <Button Width="120" Height="42" Content="保存布局" Click="SaveLayout_Click" />
                                <Button Width="120"
                                        Height="42"
                                        Margin="12,0,0,0"
                                        Content="刷新列表"
                                        Click="ReloadLayouts_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>

                            <Border Margin="0,20,0,0"
                                    Padding="16"
                                    Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="建议" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="先保存一个“默认布局”，以后桌面图标被打乱时恢复会很方便。"
                                               Foreground="{StaticResource StrongTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="已保存布局" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="选中一个布局后可恢复桌面图标位置，也可以删除旧快照。"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>

                                <Border Grid.Column="1" Style="{StaticResource PillBorderStyle}">
                                    <TextBlock Text="{Binding SavedLayouts.Count, StringFormat=共 {0} 项}" Foreground="{StaticResource MutedTextBrush}" />
                                </Border>
                            </Grid>

                            <Border Grid.Row="1"
                                    Margin="0,18,0,0"
                                    Padding="14"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedLayout.Name, TargetNullValue=选择布局后查看预览}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding SelectedLayout.DisplayText, TargetNullValue=从下方列表选择一个布局快照。}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Style="{StaticResource PillBorderStyle}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding SelectedLayout.ItemCount, TargetNullValue=0, StringFormat=预览 {0} 个图标}"
                                                       Foreground="{StaticResource StrongTextBrush}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Margin="0,14,0,0"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            ClipToBounds="True"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="SelectedLayoutPreview_MouseLeftButtonUp">
                                        <Grid Height="220">
                                            <Border Background="{StaticResource SurfaceAltBrush}" />
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="暂无大图预览"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="选择或重新保存布局后查看"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <Image Source="{Binding SelectedLayout.PreviewImage}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Margin="0,18,0,0"
                                    Padding="12"
                                    MaxHeight="360"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <ListBox ItemsSource="{Binding SavedLayouts}"
                                         SelectedItem="{Binding SelectedLayout}"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:LayoutSummaryViewModel}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="148"
                                                        Height="88"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        BorderBrush="{StaticResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        ClipToBounds="True"
                                                        VerticalAlignment="Top"
                                                        Cursor="Hand"
                                                        MouseLeftButtonUp="LayoutItemPreview_MouseLeftButtonUp">
                                                    <Grid>
                                                        <Border Background="{StaticResource SurfaceAltBrush}" />
                                                        <StackPanel VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center">
                                                            <TextBlock Text="暂无预览"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="保存时自动生成"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                        <Image Source="{Binding ThumbnailImage}"
                                                               Stretch="UniformToFill" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="14,0,12,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding DisplayText}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,10,0,0"
                                                               Text="桌面图标位置快照"
                                                               FontSize="12"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Style="{StaticResource PillBorderStyle}"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding ItemCount, StringFormat={}{0} 个图标}"
                                                               Foreground="{StaticResource StrongTextBrush}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,18,0,0">
                                <Button Width="120" Height="42" Content="恢复布局" Click="RestoreLayout_Click" />
                                <Button Width="120"
                                        Height="42"
                                        Margin="12,0,0,0"
                                        Content="删除布局"
                                        Click="DeleteLayout_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="壁纸">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,14,4,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.9*" />
                            <ColumnDefinition Width="1.1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,12,12"
                                Padding="18"
                                Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,14,0">
                                        <Border Style="{StaticResource PillBorderStyle}"
                                                Background="{StaticResource AccentSoftBrush}"
                                                BorderBrush="{StaticResource AccentSoftBrush}"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="壁纸轮换"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Margin="0,12,0,0"
                                                   Text="图源与轮换"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="把常用图源、启动切换和定时轮换都收在一处，减少来回找入口。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Padding="14,12"
                                            Style="{StaticResource InsetCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="当前状态"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding WallpaperScheduleText}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding WallpaperSourceSummaryText}"
                                                       Foreground="{StaticResource StrongTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Height="40"
                                                        Content="立即切换"
                                                        Click="ChangeWallpaperNow_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsWallpaperChangeInProgress}" Value="True">
                                                                    <Setter Property="Content" Value="切换中..." />
                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="2"
                                                        Height="40"
                                                        Content="收藏当前"
                                                        Click="SaveFavoriteWallpaper_Click"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Margin="0,0,10,0"
                                            Padding="14,12"
                                            Style="{StaticResource InsetCardBorderStyle}">
                                        <StackPanel>
                                            <CheckBox Content="启动后自动切换一张壁纸"
                                                      FontWeight="SemiBold"
                                                      IsChecked="{Binding WallpaperChangeOnStartupEnabled}" />
                                            <TextBlock Margin="24,6,0,0"
                                                       Text="保存后生效，适合把每次开机的桌面状态直接刷新成新图。"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Padding="14,12"
                                            Style="{StaticResource InsetCardBorderStyle}">
                                        <StackPanel>
                                            <CheckBox Content="启用定时轮换"
                                                      FontWeight="SemiBold"
                                                      IsChecked="{Binding WallpaperAutoRotateEnabled}" />
                                            <TextBlock Margin="24,6,0,0"
                                                       Text="后台只读取已保存配置，避免编辑中的勾选项直接影响轮换。"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock VerticalAlignment="Center"
                                                           Text="轮换间隔（分钟）"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                                <TextBox Grid.Column="1"
                                                         Height="38"
                                                         Margin="10,0,0,0"
                                                         VerticalContentAlignment="Center"
                                                         IsEnabled="{Binding WallpaperAutoRotateEnabled}"
                                                         Text="{Binding WallpaperRotationIntervalMinutesInput, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,0,12"
                                Padding="18"
                                Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock
                                           Text="添加自定义源"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="支持在线图片地址，也支持直接选择本地图片或包含图片的文件夹。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />

                                <Grid Margin="0,14,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               Text="名称"
                                               FontWeight="SemiBold" />
                                    <TextBox Grid.Column="1"
                                             Height="38"
                                             Margin="10,0,0,0"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding NewWallpaperSourceName, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="1"
                                               Margin="0,12,0,0"
                                               VerticalAlignment="Center"
                                               Text="地址/路径"
                                               FontWeight="SemiBold" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Height="38"
                                             Margin="10,12,0,0"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding NewWallpaperSourceUrl, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <WrapPanel Margin="0,14,0,0">
                                    <Button Width="138"
                                            Margin="0,0,10,10"
                                            Content="添加到图源库"
                                            Click="AddWallpaperSource_Click" />
                                    <Button Width="118"
                                            Margin="0,0,10,10"
                                            Content="选择本地图片"
                                            Click="SelectLocalWallpaperFile_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Width="118"
                                            Margin="0,0,10,10"
                                            Content="选择文件夹"
                                            Click="SelectLocalWallpaperFolder_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Padding="18"
                                Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="图源库"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="内置源建议按需停用；自定义接口、本地图片和本地文件夹都支持删除，并会跟随本地配置一起保存。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource PillBorderStyle}"
                                            Background="{StaticResource SurfaceAltBrush}">
                                        <TextBlock Text="{Binding WallpaperSourceSummaryText}"
                                                   Foreground="{StaticResource StrongTextBrush}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                                <Border Margin="0,14,0,0"
                                        Padding="10"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <ListBox ItemsSource="{Binding WallpaperSources}"
                                             MaxHeight="190"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Focusable" Value="False" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type viewModels:WallpaperSourceViewModel}">
                                                <Border Margin="0,0,0,8"
                                                        Padding="14,12"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="16">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasHealthIssue}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource ActionBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Margin="0,0,12,0">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <CheckBox Content="{Binding Name}"
                                                                          FontWeight="SemiBold"
                                                                          VerticalAlignment="Center"
                                                                          IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                                <WrapPanel Grid.Column="1"
                                                                           Margin="12,0,0,0"
                                                                           VerticalAlignment="Center">
                                                                    <Border Style="{StaticResource PillBorderStyle}"
                                                                            Padding="10,4"
                                                                            Background="{StaticResource SurfaceAltBrush}">
                                                                        <TextBlock Text="{Binding SourceTypeText}"
                                                                                   FontSize="12"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource MutedTextBrush}" />
                                                                    </Border>
                                                                    <Border Margin="8,0,0,0"
                                                                            Padding="10,4"
                                                                            BorderThickness="1"
                                                                            CornerRadius="999">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                                        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentSoftStrongBrush}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding EnabledText}"
                                                                                   FontSize="12"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource StrongTextBrush}" />
                                                                    </Border>
                                                                    <Border Margin="8,0,0,0"
                                                                            Padding="10,4"
                                                                            BorderThickness="1"
                                                                            CornerRadius="999">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentSoftStrongBrush}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasHealthIssue}" Value="True">
                                                                                        <Setter Property="Background" Value="{StaticResource ActionSoftBrush}" />
                                                                                        <Setter Property="BorderBrush" Value="{StaticResource ActionBrush}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding AvailabilityText}"
                                                                                   FontSize="12"
                                                                                   FontWeight="SemiBold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasHealthIssue}" Value="True">
                                                                                            <Setter Property="Foreground" Value="{StaticResource ActionBrush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Border>
                                                                </WrapPanel>
                                                            </Grid>

                                                            <TextBlock Margin="24,8,0,0"
                                                                       Text="{Binding RequestUrl}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="24,6,0,0"
                                                                       FontSize="12"
                                                                       Text="{Binding AvailabilityDetailText}"
                                                                       TextWrapping="Wrap">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasHealthIssue}" Value="True">
                                                                                <Setter Property="Foreground" Value="{StaticResource ActionBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1"
                                                                    VerticalAlignment="Top">
                                                            <Button Width="74"
                                                                    Height="34"
                                                                    Margin="0,0,0,8"
                                                                    Content="重选"
                                                                    Click="ReselectLocalWallpaperFile_Click"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Visibility="{Binding CanReselect, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            <Button Width="74"
                                                                    Height="34"
                                                                    Content="删除"
                                                                    Click="DeleteWallpaperSource_Click"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Visibility="{Binding CanDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <TextBlock Margin="0,12,0,0"
                                           Text="轮换会优先使用已保存且启用的图源，切换成功后继续预取下一张以减少等待；喜欢当前这张时也可以直接收藏到本地。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />

                                <WrapPanel Margin="0,14,0,0">
                                    <Button Width="132"
                                            Margin="0,0,10,10"
                                            Content="保存壁纸设置"
                                            Click="SaveWallpaperSettings_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Width="116"
                                            Margin="0,0,10,10"
                                            Content="重新加载"
                                            Click="ReloadWallpaperSettings_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Width="116"
                                            Margin="0,0,10,10"
                                            Content="全部启用"
                                            Click="EnableAllWallpaperSources_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="启动行为" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="控制应用何时启动、是否直接进入托盘。" Foreground="{StaticResource MutedTextBrush}" />

                                <CheckBox Margin="0,18,0,0"
                                          Content="开机自启"
                                          IsChecked="{Binding LaunchAtStartupEnabled}" />
                                <TextBlock Margin="24,6,0,0" Text="当前用户登录 Windows 后自动启动应用。" Foreground="{StaticResource MutedTextBrush}" />

                                <CheckBox Margin="0,18,0,0"
                                          Content="启动时最小化到托盘"
                                          IsChecked="{Binding StartMinimizedToTrayEnabled}" />
                                <TextBlock Margin="24,6,0,0" Text="启动后不弹出主窗口，直接在托盘后台运行。" Foreground="{StaticResource MutedTextBrush}" />

                                <CheckBox Margin="0,18,0,0"
                                          Content="最小化时隐藏到托盘"
                                          IsChecked="{Binding MinimizeToTrayOnMinimizeEnabled}" />
                                <TextBlock Margin="24,6,0,0" Text="点击最小化后不保留任务栏窗口，直接进入托盘。" Foreground="{StaticResource MutedTextBrush}" />

                                <CheckBox Margin="0,18,0,0"
                                          Content="关闭窗口时隐藏到托盘"
                                          IsChecked="{Binding CloseToTrayOnCloseEnabled}" />
                                <TextBlock Margin="24,6,0,0" Text="点击右上角关闭按钮时不退出程序，而是隐藏到托盘。" Foreground="{StaticResource MutedTextBrush}" />

                                <TextBlock Margin="0,18,0,0" Text="默认模式" FontWeight="SemiBold" />
                                <ComboBox Margin="0,8,0,0"
                                          Height="40"
                                          ItemsSource="{Binding ModeOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding DefaultModeId, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="应用启动后会自动切到这里选中的模式。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="快捷键与保存" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="修改会保存到本机，并在下次启动时继续生效。" Foreground="{StaticResource MutedTextBrush}" />

                                <TextBlock Margin="0,18,0,0" Text="桌面图标切换快捷键" FontWeight="SemiBold" />
                                <TextBox Margin="0,8,0,0"
                                         Height="40"
                                         IsReadOnly="True"
                                         Cursor="Hand"
                                         ToolTip="点击后直接按组合键"
                                         PreviewMouseLeftButtonDown="HotkeyCapture_PreviewMouseLeftButtonDown"
                                         GotKeyboardFocus="HotkeyCapture_GotKeyboardFocus"
                                         PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                         PreviewTextInput="HotkeyCapture_PreviewTextInput"
                                         Tag="DesktopToggle"
                                         Text="{Binding DesktopToggleHotkeyInput, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="点击输入框后直接按组合键即可录入，支持 Ctrl、Alt、Shift、Win。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />

                                <TextBlock Margin="0,18,0,0" Text="主窗口显隐快捷键" FontWeight="SemiBold" />
                                <TextBox Margin="0,8,0,0"
                                         Height="40"
                                         IsReadOnly="True"
                                         Cursor="Hand"
                                         ToolTip="点击后直接按组合键"
                                         PreviewMouseLeftButtonDown="HotkeyCapture_PreviewMouseLeftButtonDown"
                                         GotKeyboardFocus="HotkeyCapture_GotKeyboardFocus"
                                         PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                         PreviewTextInput="HotkeyCapture_PreviewTextInput"
                                         Tag="ShowMainWindow"
                                         Text="{Binding ShowMainWindowHotkeyInput, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="窗口在前台时按一下可收进托盘，窗口已隐藏或不在前台时按一下可直接拉回主窗口。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />

                                <TextBlock Margin="0,18,0,0" Text="收藏壁纸保存路径" FontWeight="SemiBold" />
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Height="40"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding WallpaperFavoriteSaveDirectoryInput, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1"
                                            Width="96"
                                            Height="40"
                                            Margin="10,0,0,0"
                                            Content="选择文件夹"
                                            Click="SelectFavoriteWallpaperSaveDirectory_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                                <TextBlock Margin="0,8,0,0"
                                           Text="仅影响“收藏当前”的保存位置；留空时会回到默认目录。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />

                                <Border Margin="0,18,0,0"
                                        Padding="16"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <TextBlock Text="输入规则" FontWeight="SemiBold" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="两个快捷键都必须包含至少一个修饰键和一个主按键，按 Esc 可取消本次录入。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <WrapPanel Margin="0,22,0,0">
                                    <Button Width="120" Height="42" Content="保存设置" Click="SaveSettings_Click" />
                                    <Button Width="120"
                                            Height="42"
                                            Margin="12,0,0,0"
                                            Content="重新加载"
                                            Click="ReloadSettings_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>


