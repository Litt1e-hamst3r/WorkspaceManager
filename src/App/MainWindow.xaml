<Window x:Class="WorkspaceManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workspace Manager"
        Height="560"
        Width="760"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Workspace Manager" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Margin="0,10,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#52525B" />
        </StackPanel>

        <TabControl Grid.Row="1" Margin="0,20,0,0">
            <TabItem Header="概览">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,10,0" Padding="16" Background="#F4F4F5" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="当前状态" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Margin="0,10,0,0" Text="{Binding DesktopIconStateText}" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding HotkeyText}" />
                            <TextBlock Margin="0,6,0,0" Text="托盘右键或全局快捷键都可以快速切换桌面图标。" TextWrapping="Wrap" Foreground="#52525B" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="10,0,0,0" Padding="16" Background="#F4F4F5" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="快捷操作" FontWeight="SemiBold" FontSize="16" />
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Width="150" Height="36" Content="切换桌面图标" Click="ToggleDesktopIcons_Click" />
                                <Button Width="120" Height="36" Margin="12,0,0,0" Content="刷新状态" Click="RefreshState_Click" />
                            </StackPanel>
                            <TextBlock Margin="0,12,0,0" Text="支持最小化到托盘、关闭隐藏到托盘。" Foreground="#52525B" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="布局">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,10,0" Padding="16" Background="#F4F4F5" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="保存当前布局" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Margin="0,8,0,0" Text="输入名称后，保存当前桌面图标的位置快照。" Foreground="#52525B" TextWrapping="Wrap" />
                            <TextBox Margin="0,14,0,0"
                                     Height="34"
                                     Text="{Binding LayoutNameInput, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Width="120" Height="36" Content="保存布局" Click="SaveLayout_Click" />
                                <Button Width="120" Height="36" Margin="12,0,0,0" Content="刷新列表" Click="ReloadLayouts_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="10,0,0,0" Padding="16" Background="#F4F4F5" CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="已保存布局" FontWeight="SemiBold" FontSize="16" />
                                <TextBlock Margin="0,8,0,0" Text="选中布局后可恢复桌面图标位置，也可以删除旧快照。" Foreground="#52525B" />
                            </StackPanel>

                            <ListBox Grid.Row="1"
                                     Margin="0,14,0,0"
                                     ItemsSource="{Binding SavedLayouts}"
                                     SelectedItem="{Binding SelectedLayout}"
                                     DisplayMemberPath="DisplayText" />

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Width="120" Height="36" Content="恢复布局" Click="RestoreLayout_Click" />
                                <Button Width="120" Height="36" Margin="12,0,0,0" Content="删除布局" Click="DeleteLayout_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="设置">
                <Border Margin="16" Padding="18" Background="#FAFAFA" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="设置" FontWeight="SemiBold" FontSize="18" />
                        <TextBlock Margin="0,6,0,0" Text="这些设置会保存在本机，并在下次启动时生效。" Foreground="#52525B" />

                        <CheckBox Margin="0,16,0,0"
                                  Content="开机自启"
                                  IsChecked="{Binding LaunchAtStartupEnabled}" />
                        <TextBlock Margin="24,4,0,0" Text="当前用户登录 Windows 后自动启动应用。" Foreground="#71717A" />

                        <CheckBox Margin="0,16,0,0"
                                  Content="启动时最小化到托盘"
                                  IsChecked="{Binding StartMinimizedToTrayEnabled}" />
                        <TextBlock Margin="24,4,0,0" Text="启动后不弹出主窗口，直接在托盘后台运行。" Foreground="#71717A" />

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Width="120" Height="36" Content="保存设置" Click="SaveSettings_Click" />
                            <Button Width="120" Height="36" Margin="12,0,0,0" Content="重新加载" Click="ReloadSettings_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
