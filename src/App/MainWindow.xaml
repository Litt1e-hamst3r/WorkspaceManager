<Window x:Class="WorkspaceManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:WorkspaceManager.App.ViewModels"
        Title="Workspace Manager"
        Height="640"
        Width="920"
        MinHeight="560"
        MinWidth="820"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding AppName}"
                       FontSize="26"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <Border Grid.Column="1"
                    Margin="16,0,0,0"
                    Padding="12,8"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding DesktopIconStateText}"
                           Foreground="{StaticResource StrongTextBrush}"
                           FontWeight="SemiBold" />
            </Border>

            <Border Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="12,8"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding TaskbarStateText}"
                           Foreground="{StaticResource StrongTextBrush}"
                           FontWeight="SemiBold" />
            </Border>

            <Border Grid.Column="3"
                    Margin="12,0,0,0"
                    Padding="12,8"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding HotkeyText}"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>

        <TabControl Grid.Row="1" Margin="0,20,0,0">
            <TabItem Header="概览">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <Border Style="{StaticResource PillBorderStyle}"
                                        Background="{StaticResource AccentSoftBrush}"
                                        BorderBrush="{StaticResource AccentSoftBrush}"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="工作区状态"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Margin="0,16,0,0"
                                           Text="当前桌面控制入口"
                                           FontSize="24"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="图标、任务栏、托盘与快捷键都集中在这里，日常切换会更直接。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />

                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="桌面图标"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                        <Border Margin="0,10,0,0"
                                                Style="{StaticResource SegmentGroupBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Content="显示"
                                                        Click="ShowDesktopIcons_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDesktopIconsVisible}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="1"
                                                        Content="隐藏"
                                                        Click="HideDesktopIcons_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDesktopIconsVisible}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="任务栏"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                        <Border Margin="0,10,0,0"
                                                Style="{StaticResource SegmentGroupBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Content="显示"
                                                        Click="ShowTaskbar_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTaskbarVisible}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Grid.Column="1"
                                                        Content="隐藏"
                                                        Click="HideTaskbar_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTaskbarVisible}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Width="120"
                                            Height="42"
                                            Margin="12,23,0,0"
                                            Content="刷新状态"
                                            Click="RefreshState_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>

                                <Border Margin="0,22,0,0"
                                        Padding="16"
                                        Background="{StaticResource SurfaceAltBrush}"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="桌面图标" FontWeight="SemiBold" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding DesktopIconStateText}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                            <TextBlock Text="任务栏" FontWeight="SemiBold" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding TaskbarStateText}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="当前状态" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding HotkeyText}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="双击托盘图标可恢复窗口，快捷键可快速切换桌面图标。"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="运行方式" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,14,0,0" Text="• 最小化自动进入托盘" />
                                    <TextBlock Margin="0,8,0,0" Text="• 关闭窗口不退出程序" />
                                    <TextBlock Margin="0,8,0,0" Text="• 任务栏可单独隐藏或恢复" />
                                    <TextBlock Margin="0,8,0,0" Text="• 支持开机自启与启动最小化" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="布局">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <Border Style="{StaticResource PillBorderStyle}"
                                    Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="布局快照"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </Border>

                            <TextBlock Margin="0,16,0,0" Text="保存当前布局" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="把当前桌面图标位置保存成快照，之后可以一键恢复。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0" Text="布局名称" FontWeight="SemiBold" />
                            <TextBox Margin="0,8,0,0"
                                     Height="40"
                                     Text="{Binding LayoutNameInput, UpdateSourceTrigger=PropertyChanged}" />

                            <WrapPanel Margin="0,18,0,0">
                                <Button Width="120" Height="42" Content="保存布局" Click="SaveLayout_Click" />
                                <Button Width="120"
                                        Height="42"
                                        Margin="12,0,0,0"
                                        Content="刷新列表"
                                        Click="ReloadLayouts_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>

                            <Border Margin="0,20,0,0"
                                    Padding="16"
                                    Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="建议" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="先保存一个“默认布局”，以后桌面图标被打乱时恢复会很方便。"
                                               Foreground="{StaticResource StrongTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="已保存布局" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="选中一个布局后可恢复桌面图标位置，也可以删除旧快照。"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>

                                <Border Grid.Column="1" Style="{StaticResource PillBorderStyle}">
                                    <TextBlock Text="{Binding SavedLayouts.Count, StringFormat=共 {0} 项}" Foreground="{StaticResource MutedTextBrush}" />
                                </Border>
                            </Grid>

                            <Border Grid.Row="1"
                                    Margin="0,18,0,0"
                                    Padding="14"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedLayout.Name, TargetNullValue=选择布局后查看预览}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding SelectedLayout.DisplayText, TargetNullValue=从下方列表选择一个布局快照。}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Style="{StaticResource PillBorderStyle}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding SelectedLayout.ItemCount, TargetNullValue=0, StringFormat=预览 {0} 个图标}"
                                                       Foreground="{StaticResource StrongTextBrush}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Margin="0,14,0,0"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            ClipToBounds="True"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="SelectedLayoutPreview_MouseLeftButtonUp">
                                        <Grid Height="220">
                                            <Border Background="{StaticResource SurfaceAltBrush}" />
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="暂无大图预览"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="选择或重新保存布局后查看"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <Image Source="{Binding SelectedLayout.PreviewImage}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Margin="0,18,0,0"
                                    Padding="12"
                                    MaxHeight="360"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <ListBox ItemsSource="{Binding SavedLayouts}"
                                         SelectedItem="{Binding SelectedLayout}"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:LayoutSummaryViewModel}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="148"
                                                        Height="88"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        BorderBrush="{StaticResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        ClipToBounds="True"
                                                        VerticalAlignment="Top"
                                                        Cursor="Hand"
                                                        MouseLeftButtonUp="LayoutItemPreview_MouseLeftButtonUp">
                                                    <Grid>
                                                        <Border Background="{StaticResource SurfaceAltBrush}" />
                                                        <StackPanel VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center">
                                                            <TextBlock Text="暂无预览"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="保存时自动生成"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                        <Image Source="{Binding ThumbnailImage}"
                                                               Stretch="UniformToFill" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="14,0,12,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding DisplayText}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,10,0,0"
                                                               Text="桌面图标位置快照"
                                                               FontSize="12"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Style="{StaticResource PillBorderStyle}"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding ItemCount, StringFormat={}{0} 个图标}"
                                                               Foreground="{StaticResource StrongTextBrush}"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,18,0,0">
                                <Button Width="120" Height="42" Content="恢复布局" Click="RestoreLayout_Click" />
                                <Button Width="120"
                                        Height="42"
                                        Margin="12,0,0,0"
                                        Content="删除布局"
                                        Click="DeleteLayout_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid Margin="4,18,4,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="启动行为" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0" Text="控制应用何时启动、是否直接进入托盘。" Foreground="{StaticResource MutedTextBrush}" />

                            <CheckBox Margin="0,18,0,0"
                                      Content="开机自启"
                                      IsChecked="{Binding LaunchAtStartupEnabled}" />
                            <TextBlock Margin="24,6,0,0" Text="当前用户登录 Windows 后自动启动应用。" Foreground="{StaticResource MutedTextBrush}" />

                            <CheckBox Margin="0,18,0,0"
                                      Content="启动时最小化到托盘"
                                      IsChecked="{Binding StartMinimizedToTrayEnabled}" />
                            <TextBlock Margin="24,6,0,0" Text="启动后不弹出主窗口，直接在托盘后台运行。" Foreground="{StaticResource MutedTextBrush}" />

                            <CheckBox Margin="0,18,0,0"
                                      Content="最小化时隐藏到托盘"
                                      IsChecked="{Binding MinimizeToTrayOnMinimizeEnabled}" />
                            <TextBlock Margin="24,6,0,0" Text="点击最小化后不保留任务栏窗口，直接进入托盘。" Foreground="{StaticResource MutedTextBrush}" />

                            <CheckBox Margin="0,18,0,0"
                                      Content="关闭窗口时隐藏到托盘"
                                      IsChecked="{Binding CloseToTrayOnCloseEnabled}" />
                            <TextBlock Margin="24,6,0,0" Text="点击右上角关闭按钮时不退出程序，而是隐藏到托盘。" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="快捷键与保存" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0" Text="修改会保存到本机，并在下次启动时继续生效。" Foreground="{StaticResource MutedTextBrush}" />

                            <TextBlock Margin="0,18,0,0" Text="桌面图标切换快捷键" FontWeight="SemiBold" />
                            <TextBox Margin="0,8,0,0"
                                     Height="40"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     ToolTip="点击后直接按组合键"
                                     PreviewMouseLeftButtonDown="HotkeyCapture_PreviewMouseLeftButtonDown"
                                     GotKeyboardFocus="HotkeyCapture_GotKeyboardFocus"
                                     PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                     PreviewTextInput="HotkeyCapture_PreviewTextInput"
                                     Tag="DesktopToggle"
                                     Text="{Binding DesktopToggleHotkeyInput, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="点击输入框后直接按组合键即可录入，支持 Ctrl、Alt、Shift、Win。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0" Text="显示主窗口快捷键" FontWeight="SemiBold" />
                            <TextBox Margin="0,8,0,0"
                                     Height="40"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     ToolTip="点击后直接按组合键"
                                     PreviewMouseLeftButtonDown="HotkeyCapture_PreviewMouseLeftButtonDown"
                                     GotKeyboardFocus="HotkeyCapture_GotKeyboardFocus"
                                     PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                     PreviewTextInput="HotkeyCapture_PreviewTextInput"
                                     Tag="ShowMainWindow"
                                     Text="{Binding ShowMainWindowHotkeyInput, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="当任务栏被隐藏或窗口已缩到托盘时，可用这个快捷键直接拉回主窗口。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />

                            <Border Margin="0,18,0,0"
                                    Padding="16"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="输入规则" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="两个快捷键都必须包含至少一个修饰键和一个主按键，按 Esc 可取消本次录入。"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,22,0,0">
                                <Button Width="120" Height="42" Content="保存设置" Click="SaveSettings_Click" />
                                <Button Width="120"
                                        Height="42"
                                        Margin="12,0,0,0"
                                        Content="重新加载"
                                        Click="ReloadSettings_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
